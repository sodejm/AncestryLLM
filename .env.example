# Development/headless fallback only. AncestryLLM never auto-loads this file.
# Prefer `ancestry secrets set NAME`, which stores values in the OS keyring.
# CI values belong in the runner's secret manager. Never commit real values.

ANCESTRYLLM_CONFIG_DIR=
ANCESTRYLLM_DATA_DIR=
ANCESTRYLLM_DATABASE_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_MANAGEMENT_KEY=
