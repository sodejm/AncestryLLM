# Never put real secrets in this committed template. Copy it to .env first.

# Shared/local services
OLLAMA_BASE_URL=
OLLAMA_MODEL=
OLLAMA_NUM_CTX=
SQL_AGENT_TOP_K=
OPEN_WEBUI_DATA_DIR=./open-webui-data
FAMILY_TREES_HOST_DIR=./family_trees
FAMILY_TREES_DIR=/app/backend/data/family_trees
WEBUI_SECRET_KEY=
DEPLOYMENT_MODE=localhost
WEBUI_ADMIN_EMAIL=admin@localhost
WEBUI_ADMIN_PASSWORD=
OLLAMA_BOOTSTRAP_MODELS=gemma4,llama3.1,qwen3,mistral

# Optional cloud providers
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
GEMINI_API_KEY=
# GOOGLE_API_KEY is accepted as a Gemini alternative. Set only one.
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
OPENROUTER_API_KEY=
# Required for an account-level OpenRouter balance check in strict mode.
OPENROUTER_MANAGEMENT_KEY=
OPENROUTER_MODEL=openrouter/auto
OPENROUTER_COST_QUALITY=7
OPENROUTER_ZDR=true

# GEDCOM Merge Tool
GEDCOM_AI_BACKEND=ollama
AI_REASONING_EFFORT=low
REMOTE_CREDIT_CHECK=required
MINIMUM_REMOTE_CREDIT_USD=0.01

# Other optional project integrations
ANTHROPIC_API_KEY=
