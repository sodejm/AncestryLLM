{
  "name": "local-ai-genealogy-tool-dev",
  "private": true,
  "description": "Development tooling for local-ai-genealogy-tool",
  "devDependencies": {
    "bash-language-server": "5.6.0",
    "dockerfile-language-server-nodejs": "0.14.1",
    "pyright": "1.1.407",
    "sql-language-server": "1.7.1",
    "vscode-langservers-extracted": "4.10.0",
    "yaml-language-server": "1.19.2"
  },
  "scripts": {
    "dev:install-language-servers": "npm install",
    "dev:ls-pyright": "pyright-langserver --stdio",
    "dev:ls-bash": "bash-language-server start",
    "dev:ls-yaml": "yaml-language-server --stdio",
    "dev:ls-dockerfile": "docker-langserver --stdio",
    "dev:ls-json": "vscode-json-language-server --stdio",
    "dev:ls-sql": "sql-language-server up --method stdio"
  }
}
